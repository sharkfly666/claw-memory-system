{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-proposals.v1.schema.json",
  "title": "Skill Proposals Store V1",
  "type": "object",
  "required": ["schema_version", "proposals"],
  "properties": {
    "schema_version": { "const": "skill-proposals.v1" },
    "updated_at": { "type": "string" },
    "proposals": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["proposal_id", "created_at", "updated_at"],
        "properties": {
          "proposal_id": { "type": "string" },
          "skill_id": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string" },
          "proposed_by_model": { "type": ["string", "null"] },
          "source_task_ids": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      }
    }
  }
}
