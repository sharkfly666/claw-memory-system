{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claw-memory-system.local/schemas/facts.v1.schema.json",
  "title": "Claw Memory System Facts v1",
  "type": "object",
  "required": ["version", "updated_at", "facts"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "updated_at": { "type": "string", "format": "date-time" },
    "facts": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/fact" }
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "required": ["value", "value_type", "category", "status", "updated_at", "source"],
      "properties": {
        "value": {},
        "value_type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object", "null"]
        },
        "category": {
          "type": "string",
          "enum": ["fact", "preference", "decision", "project_state", "entity", "other"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "stale", "superseded", "expired", "archived"]
        },
        "updated_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_verified": { "type": ["string", "null"], "format": "date-time" },
        "valid_from": { "type": ["string", "null"], "format": "date-time" },
        "valid_to": { "type": ["string", "null"], "format": "date-time" },
        "ttl_days": { "type": ["integer", "null"], "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string" },
        "scope": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
